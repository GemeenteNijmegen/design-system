{
  "utrecht": {
    "form-field": {
      "margin-block-end": {
        "value": "{nijmegen.space.0}",
        "type": "spacing",
        "description": "[code-only]"
      },
      "margin-block-start": {
        "value": "{nijmegen.space.0}",
        "type": "spacing",
        "description": "[code-only]"
      },
      "invalid": {
        "border-inline-start-color": {
          "type": "color",
          "value": "{nijmegen.color.feedback.error.default}"
        },
        "border-inline-start-width": {
          "type": "borderWidth",
          "value": "{nijmegen.border-width.md}"
        },
        "padding-inline-start": {
          "type": "spacing",
          "value": "{nijmegen.space.100}"
        }
      }
    }
  }
}